{
	"id": "2021-01_poteaux",
	"title": "Poteaux électriques",
	"start_date": "2020-10-01",
	"end_date": "2024-01-01",
	"summary": "Les poteaux électriques supportent plusieurs réseaux aériens utiles, électriques ou de télécommunication. Les repérer présente plusieurs avantages. Leur maintenance et remplacement sera plus aisé ou le déploiement de la fibre optique pourra être plus rapide.",
	"links": {
		"osmwiki": "https://wiki.openstreetmap.org/wiki/Power_networks/France#R.C3.A9seaux_de_distribution",
		"osmblog": null
	},
	"database": {
		"osmium_tag_filter": "n/operator=Enedis&n/power=pole,tower"
	},
	"datasources": [
		{
			"source": "osm",
			"name": "Support dans OSM",
			"description": "Ce support existe déjà dans OSM. Vous pouvez compléter ou modifier ses informations si nécessaire.",
			"tiles": ["https://enedis.openstreetmap.fr/tiles/pdm_project_poteaux/{z}/{x}/{y}.mvt"],
			"layers": ["pdm_project_poteaux"],
			"minZoom":10,
			"maxZoom":15
		},
		{
			"source": "background",
			"tiles": [ "https://proxy-ign.openstreetmap.fr/94GjiyqD/bdortho/{z}/{x}/{y}.jpg" ],
			"name": "IGN BD Ortho",
			"attribution": "<a href=\"https://openstreetmap.fr/bdortho\" target=\"_blank\">&copy; BDOrtho IGN</a>"
		},
		{
			"source": "background",
			"tiles": [ "https://a.tile.openstreetmap.fr/volta/{z}/{x}/{y}.png" ],
			"name": "Réseaux électriques existants",
			"attribution": "Données <a href=\"https://data.enedis.fr\">Enedis</a>, <a href=\"https://www.geredis.fr/Cartographie-et-reseaux\">Gérédis</a>, <a href=\"https://opendata.srd-energies.fr/pages/page-accueil/\">SRD</a> et <a href=\"https://opendata.reseaux-energies.fr\">RTE France</a> - <a href=\"https://wiki.openstreetmap.org/wiki/FR:Serveurs/tile.openstreetmap.fr#Rendu_.22Volta.22_des_r.C3.A9seaux_.C3.A9lectriques\">Rendu Cquest CC BY-SA</a>"
		},
		{
			"source": "stats",
			"tiles": ["https://enedis.openstreetmap.fr/tiles/pdm_stats_poteaux/{z}/{x}/{y}.mvt"],
			"layers": ["pdm_stats_poteaux"],
			"name": "Statistiques géographiques"
		}
	],
	"statistics": {
		"count": true,
		"feature_name": "poteaux",
		"points": { "add": 3, "edit": 1, "note": 1 },
		"osmose_tasks": "Postes intégrés depuis l'opendata"
	},
	"editors": {
		"all": {
			"comment": "[Enedis/France] Ajout de poteaux électriques",
			"hashtags": "convenedisosmfr,gespot"
		},
		"pdm": {
			"fields": [
				{ "type": "hidden", "tags": { "power": "pole", "operator": "Enedis" } },
				{ "type": "text", "name": "Opérateur / gestionnaire (identique sur la commune)", "tag": "operator", "optional": false },
				{ "type": "select", "name": "Quel matériau ?", "tag": "material", "optional": true, "values": [
					{ "v": "wood", "l": "Bois" },
					{ "v": "concrete", "l": "Béton" },
					{ "v": "metal", "l": "Métal" },
					{ "v": "composite", "l": "Composite" }
				] },
				{ "type": "select", "name": "Quel armement ?", "tag": "line_attachment", "optional": true, "values": [
					{ "v": "anchor", "l": "Ancrage" },
					{ "v": "suspension", "l": "Suspension" },
					{ "v": "pin", "l": "Supporté" }
				] },
				{ "type": "2states", "name": "Transition aéro-souterraine ?", "tag": "location:transition" },
				{ "type": "textarea", "name": "Autres informations", "tag": "note", "description": "Horaires, modèle, infos pratiques...", "optional": true }
			],
			"title": {
				"add": "Ajoutez un poteau manquant",
				"edit": "Complétez ce poteau"
			}
		},
		"iD": {
			"background": "fr.ign.bdortho"
		}
	},
	"opendata": [
		{ "title": "Extraction locale", "via": "enedis.openstreetmap.fr", "url": "/extracts/poteaux.csv" }
	]
